# ── Авторизация admin-панели ──────────────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=novator2026

# ── База данных ───────────────────────────────────────────────────────────────
DB_PATH=data/novator.db

# ── Gmail IMAP ────────────────────────────────────────────────────────────────
# Важно: используй App Password, не основной пароль Google!
# Создать: myaccount.google.com → Безопасность → Пароли приложений
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Только письма от банка (оставь пустым чтобы принимать все)
SENDER_FILTER=@raiffeisen.ru

# Как часто проверять почту (секунды, 900 = 15 минут)
CHECK_EVERY=900
