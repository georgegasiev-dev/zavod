# ── Авторизация admin-панели ──────────────────────────────────────────────────
# Реальные значения задаются через .env на сервере, НЕ здесь
ADMIN_USER=admin
ADMIN_PASS=your_password_here

# ── База данных ───────────────────────────────────────────────────────────────
DB_PATH=data/novator.db

# ── Raiffeisen API ────────────────────────────────────────────────────────────
RAIFFEISEN_CLIENT_ID=your_client_id
RAIFFEISEN_CLIENT_SECRET=your_client_secret
RAIFFEISEN_REFRESH_TOKEN=your_refresh_token
RAIFFEISEN_ACCOUNT=your_account_number

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TG_TOKEN=your_bot_token
TG_CHAT_ID=your_chat_id
TG_BOT_PASSWORD=your_bot_password
